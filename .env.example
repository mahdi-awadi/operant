# Operant — environment configuration (secrets + host/port overrides)
#
# Copy to your operant data dir as `.env` and fill in real values:
#   cp .env.example ~/.claude/channels/operant/.env && chmod 600 ~/.claude/channels/operant/.env
#
# The daemon loads <OPERANT_DIR>/.env itself at startup (loadDotEnv in src/config.ts).
# A real environment variable always wins over a value here.
# Precedence: these env vars OVERRIDE values in config.json.
# Structured settings (telegramAllowFrom, autopilot) stay in config.json.

# Telegram bot token from @BotFather (secret — never commit the real value)
TELEGRAM_TOKEN=

# Optional overrides (otherwise taken from config.json / defaults)
# WEB_PORT=3001
# WEB_HOST=0.0.0.0
# BROWSE_ROOT=/home
